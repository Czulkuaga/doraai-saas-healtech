// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ------------------------------------------------
// Enum
// ------------------------------------------------
enum MembershipCategory {
  SUPERADMIN
  ADMIN
  USER
  PROFESSIONAL
}

enum TenantStatus {
  ACTIVE
  SUSPENDED
  DELETED
}

enum AuthEventType {
  LOGIN_SUCCESS
  LOGIN_FAILED
  LOGOUT
  SESSION_REVOKED
  SESSION_EXPIRED
  SESSION_IDLE_TIMEOUT
  PASSWORD_RESET_REQUESTED
  PASSWORD_RESET_COMPLETED
}

enum PartnerType {
  PERSON
  ORGANIZATION
}

enum BPRoleType {
  PATIENT
  GUARDIAN
  EMERGENCY_CONTACT
  PROVIDER
  REFERRING_PROVIDER
  INSURER
  PAYER
  SUPPLIER
  LABORATORY
  PHARMACY
  CONTACT
  STAFF
}

enum Gender {
  MALE
  FEMALE
  OTHER
  UNKNOWN
}

enum NumberRangeObject {
  BUSINESS_PARTNER
  ORG_UNIT
  LOCATION
  APPOINTMENT
  PREVENTIVE_CASE
  PREVENTIVE_FOLLOW_UP
  PREVENTIVE_CAMPAIGN
}

enum TranslatableEntity {
  SPECIALTY
  SERVICE_TYPE
  ORG_UNIT
  LOCATION
}

enum TranslatableField {
  NAME
  DESCRIPTION
}

enum AddressType {
  HOME
  WORK
  BILLING
  OTHER
}

enum IdentityDocumentType {
  BELGIAN_EID
  BELGIAN_KIDS_ID
  BELGIAN_FOREIGNER_CARD
  PASSPORT
  NATIONAL_ID
  OTHER
}

enum InsuranceVerificationStatus {
  UNKNOWN
  ACTIVE
  INACTIVE
  ERROR
}

enum ExternalSystem {
  SIMPLYBOOK
  MYCARENET
  EHEALTH
  EID_READER
  OTHER
}

enum IntegrationDirection {
  INBOUND
  OUTBOUND
}

enum IntegrationSyncStatus {
  SUCCESS
  FAILED
  PARTIAL
  SKIPPED
}

enum ExternalCustomerLinkStatus {
  ACTIVE
  NOT_FOUND
  AMBIGUOUS
  DISABLED
}

enum IntegrationOperation {
  GET_TOKEN

  SEARCH_CUSTOMER
  CREATE_CUSTOMER
  UPDATE_CUSTOMER

  SEARCH_APPOINTMENT
  CREATE_APPOINTMENT
  UPDATE_APPOINTMENT
  CANCEL_APPOINTMENT

  VERIFY_INSURANCE
  READ_IDENTITY
}

enum IntegrationConnectionStatus {
  NOT_CONFIGURED
  CONNECTING
  CONNECTED
  TWO_FACTOR_REQUIRED
  EXPIRED
  ERROR
  DISABLED
}

enum IntegrationAuthType {
  API_USER_KEY
  USER_PASSWORD
  OAUTH2
  CUSTOM
}

// ------------------------------------------------
// Preventive Medicine (Transactional / Template-driven)
// ------------------------------------------------

enum PreventiveCaseStatus {
  OPEN
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum PatientProviderAssignmentType {
  PRIMARY_CARE
  PREVENTIVE_FOLLOWUP
  NURSING
  SPECIALIST_SUPPORT
  OTHER
}

enum PreventiveRiskLevel {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum PreventiveFollowUpStatus {
  PLANNED
  CONFIRMED
  IN_PROGRESS
  COMPLETED
  CANCELLED
  MISSED
}

enum FollowUpFrequency {
  NONE
  WEEKLY
  BIWEEKLY
  MONTHLY
  QUARTERLY
  SEMIANNUAL
  ANNUAL
  CUSTOM
}

enum PreventivePriority {
  LOW
  NORMAL
  HIGH
  URGENT
}

enum PreventiveOutcome {
  NORMAL
  STABLE
  IMPROVED
  ATTENTION_REQUIRED
  REFERRED
}

enum PreventiveFollowUpChannel {
  IN_PERSON
  PHONE
  VIDEO
  WHATSAPP
  HOME_VISIT
}

enum PreventiveCampaignStatus {
  DRAFT
  SCHEDULED
  RUNNING
  PAUSED
  COMPLETED
  CANCELLED
}

enum PreventiveCampaignChannel {
  WHATSAPP
  EMAIL
  SMS
  PHONE
}

enum PreventiveCampaignRecipientStatus {
  PENDING
  SENT
  DELIVERED
  READ
  RESPONDED
  FAILED
  CANCELLED
}

enum PreventiveTimelineEventType {
  CASE_CREATED
  CASE_UPDATED
  CASE_COMPLETED
  CASE_CANCELLED

  FOLLOW_UP_CREATED
  FOLLOW_UP_UPDATED
  FOLLOW_UP_COMPLETED
  FOLLOW_UP_CANCELLED
  FOLLOW_UP_MISSED

  CAMPAIGN_SENT
  PATIENT_RESPONDED

  PATHOLOGY_ADDED
  PATHOLOGY_RESOLVED

  PROVIDER_ASSIGNED
  PROVIDER_REMOVED

  NOTE_ADDED
}

// ------------------------------------------------
// Models
// ------------------------------------------------

model Tenant {
  id        String       @id @default(uuid())
  code      String       @unique // tipo SAP "BUKRS"
  name      String
  slug      String       @unique
  status    TenantStatus @default(ACTIVE)
  deletedAt DateTime?

  // Defaults (SAP-like: sociedad/empresa tiene defaults)
  countryCode         String?
  defaultLocaleCode   String
  defaultTimeZoneId   String
  defaultCurrencyCode String
  // defaultLanguageCode String
  // defaultLanguage     Language     @relation(fields: [defaultLanguageCode], references: [code])

  defaultLocale   Locale   @relation("TenantDefaultLocale", fields: [defaultLocaleCode], references: [code], onDelete: Restrict)
  defaultTimeZone TimeZone @relation(fields: [defaultTimeZoneId], references: [id], onDelete: Restrict)
  defaultCurrency Currency @relation(fields: [defaultCurrencyCode], references: [code], onDelete: Restrict)
  country         Country? @relation(fields: [countryCode], references: [code], onDelete: Restrict)

  // CORE
  orgUnits      OrgUnit[]
  locations     Location[]
  partners      BusinessPartner[]
  tenantLocales TenantLocale[]
  serviceTypes  ServiceType[]
  specialties   Specialty[]
  numberRanges  NumberRange[]
  memberships   TenantMembership[]

  //Preventive Medicine
  preventiveCases              PreventiveCase[]
  preventiveFollowUps          PreventiveFollowUp[]
  preventiveCampaigns          PreventiveCampaign[]
  preventiveCampaignRecipients PreventiveCampaignRecipient[]
  preventiveTimelineEvents     PreventiveTimelineEvent[]

  // users      TenantMembership[]
  roles      Role[]
  sessions   Session[]
  auditLogs  AuditLog[]
  authEvents AuthEvent[]

  createdAt                  DateTime                    @default(now())
  updatedAt                  DateTime                    @updatedAt
  businessPartnerRoles       BusinessPartnerRole[]
  patientProviderAssignments PatientProviderAssignment[]
  pathologies                Pathology[]
  patientPathologies         PatientPathology[]
}

model OrgUnit {
  id       String  @id @default(uuid())
  tenantId String
  isActive Boolean @default(true)

  // SAP-like org unit key
  code String
  name String

  // Parent by business key (tenant-scoped)
  parentCode String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  // composite self-relation: (tenantId,parentCode) -> (tenantId,code)
  parent   OrgUnit?  @relation("OrgHierarchy", fields: [tenantId, parentCode], references: [tenantId, code], onDelete: Restrict)
  children OrgUnit[] @relation("OrgHierarchy")

  preventiveCases     PreventiveCase[]
  preventiveFollowUps PreventiveFollowUp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, parentCode])
}

model Location {
  id       String  @id @default(uuid())
  tenantId String
  isActive Boolean @default(true)

  code String
  name String

  addressLine1 String?
  city         String?
  postalCode   String?

  countryCode String?
  country     Country? @relation(fields: [countryCode], references: [code], onDelete: Restrict)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  preventiveCases     PreventiveCase[]
  preventiveFollowUps PreventiveFollowUp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([countryCode])
}

model TenantLocale {
  id         String  @id @default(uuid())
  tenantId   String
  localeCode String
  isActive   Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  locale Locale @relation(fields: [localeCode], references: [code], onDelete: Restrict)

  @@unique([tenantId, localeCode])
  @@index([tenantId])
  @@index([localeCode])
}

model Translation {
  id       String  @id @default(uuid())
  tenantId String?

  entity   TranslatableEntity
  entityId String
  field    TranslatableField

  localeCode String
  value      String

  locale Locale @relation(fields: [localeCode], references: [code], onDelete: Restrict)

  @@unique([tenantId, entity, entityId, field, localeCode])
  @@index([entity, entityId])
  @@index([localeCode])
}

model ProviderProfile {
  id        String @id @default(uuid())
  partnerId String @unique // 1:1 con BP

  licenseNumber String?
  isActive      Boolean @default(true)

  partner BusinessPartner @relation(fields: [partnerId], references: [id], onDelete: Restrict)

  specialties         ProviderSpecialty[]
  preventiveCases     PreventiveCase[]
  patientAssignments  PatientProviderAssignment[] @relation("ProviderAssignments")
  preventiveFollowUps PreventiveFollowUp[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ProviderSpecialty {
  id          String  @id @default(uuid())
  providerId  String
  specialtyId String
  isPrimary   Boolean @default(false)

  provider  ProviderProfile @relation(fields: [providerId], references: [id], onDelete: Restrict)
  specialty Specialty       @relation(fields: [specialtyId], references: [id], onDelete: Restrict)

  @@unique([providerId, specialtyId])
  @@index([specialtyId])
}

model User {
  id              String  @id @default(uuid())
  email           String
  emailNormalized String  @unique
  name            String?
  firstName       String?
  lastName        String?
  phone           String?
  phoneNormalized String?
  passwordHash    String
  isActive        Boolean @default(true)

  memberships TenantMembership[]
  sessions    Session[]
  authEvents  AuthEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([phoneNormalized])
  @@index([emailNormalized])
  @@index([phoneNormalized])
}

model Role {
  id String @id @default(uuid())

  tenantId String?
  name     String
  key      String
  isSystem Boolean @default(false)
  isActive Boolean @default(true)

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  permissions RolePermission[]
  members     MembershipRole[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, key])
  @@index([tenantId])
  @@index([tenantId, isActive])
}

model Permission {
  id          String  @id @default(uuid())
  key         String  @unique
  description String?

  roles RolePermission[]
}

model RolePermission {
  id String @id @default(uuid())

  roleId       String
  permissionId String

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Restrict)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Restrict)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@index([permissionId])
}

model TenantMembership {
  id String @id @default(uuid())

  tenantId String
  userId   String

  category MembershipCategory
  isActive Boolean            @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Restrict)

  roles     MembershipRole[]
  auditLogs AuditLog[]

  createdAt DateTime @default(now())

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
  @@index([tenantId, userId])
  @@index([tenantId, isActive])
}

model MembershipRole {
  id String @id @default(uuid())

  membershipId String
  roleId       String

  membership TenantMembership @relation(fields: [membershipId], references: [id], onDelete: Restrict)
  role       Role             @relation(fields: [roleId], references: [id], onDelete: Restrict)

  @@unique([membershipId, roleId])
  @@index([membershipId])
  @@index([roleId])
}

model Session {
  id String @id @default(uuid())

  userId   String
  tenantId String

  tokenHash String @unique

  ip        String?
  userAgent String?

  expiresAt  DateTime
  revokedAt  DateTime?
  lastSeenAt DateTime?

  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([tenantId])
  @@index([expiresAt])
  @@index([revokedAt])
  @@index([tokenHash])
  @@index([tenantId, userId])
}

model AuditLog {
  id String @id @default(uuid())

  tenantId          String
  actorMembershipId String

  action       String
  resourceType String
  resourceId   String?

  method    String?
  path      String?
  ip        String?
  userAgent String?

  success  Boolean @default(true)
  message  String?
  metadata Json?

  tenant          Tenant           @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  actorMembership TenantMembership @relation(fields: [actorMembershipId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([tenantId, createdAt])
  @@index([actorMembershipId])
  @@index([action])
}

model AuthEvent {
  id String @id @default(uuid())

  tenantId String?
  userId   String?

  type    AuthEventType
  success Boolean       @default(true)
  message String?

  ip        String?
  userAgent String?
  host      String?

  metadata Json?

  createdAt DateTime @default(now())

  tenant Tenant? @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  user   User?   @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tenantId, createdAt])
  @@index([userId, createdAt])
  @@index([type, createdAt])
}

model NumberRange {
  id       String            @id @default(uuid())
  tenantId String
  object   NumberRangeObject

  prefix  String?
  nextNo  Int
  padding Int     @default(8)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  @@unique([tenantId, object])
  @@index([tenantId])
}

model BusinessPartnerRole {
  id String @id @default(uuid())

  tenantId  String
  partnerId String
  role      BPRoleType

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  partner BusinessPartner @relation(fields: [partnerId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  // Evita duplicados por partner
  @@unique([tenantId, partnerId, role])
  // Índices multi-tenant (queries reales)
  @@index([tenantId, role])
  @@index([tenantId, partnerId])
  @@index([role])
}

model BusinessPartnerAddress {
  id        String @id @default(uuid())
  tenantId  String
  partnerId String

  type      AddressType @default(HOME)
  isPrimary Boolean     @default(true)

  street      String?
  houseNumber String?
  box         String?
  postalCode  String?
  city        String?
  region      String?
  countryCode String?

  rawAddress String?

  partner BusinessPartner @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  country Country?        @relation(fields: [countryCode], references: [code], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, partnerId])
  @@index([tenantId, postalCode])
  @@index([tenantId, city])
}

model BusinessPartnerIdentity {
  id        String @id @default(uuid())
  tenantId  String
  partnerId String

  type IdentityDocumentType

  nationalNumber           String?
  nationalNumberNormalized String?

  cardNumber           String?
  cardNumberNormalized String?

  issuingCountryCode String?
  nationalityCode    String?

  validFrom DateTime?
  expiresAt DateTime?

  readAt DateTime?
  source String?

  rawData Json?

  isActive Boolean @default(true)

  replacesId String?

  partner        BusinessPartner @relation(fields: [partnerId], references: [id], onDelete: Restrict)
  issuingCountry Country?        @relation("IdentityIssuingCountry", fields: [issuingCountryCode], references: [code], onDelete: Restrict)
  nationality    Country?        @relation("IdentityNationality", fields: [nationalityCode], references: [code], onDelete: Restrict)

  replaces   BusinessPartnerIdentity?  @relation("IdentityReplacement", fields: [replacesId], references: [id], onDelete: Restrict)
  replacedBy BusinessPartnerIdentity[] @relation("IdentityReplacement")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, type, nationalNumberNormalized])
  @@index([tenantId])
  @@index([tenantId, partnerId])
  @@index([tenantId, nationalNumberNormalized])
  @@index([tenantId, cardNumberNormalized])
  @@index([tenantId, expiresAt])
  @@index([tenantId, isActive])
  @@index([tenantId, replacesId])
}

model PatientInsuranceCoverage {
  id        String @id @default(uuid())
  tenantId  String
  patientId String

  status InsuranceVerificationStatus @default(UNKNOWN)

  insurerCode   String?
  insurerName   String?
  mutualityCode String?
  mutualityName String?

  verifiedAt DateTime?
  validFrom  DateTime?
  validUntil DateTime?

  source            String? // MYCARENET, MANUAL, IMPORT
  externalReference String?

  alerts      Json?
  rawResponse Json?

  patient BusinessPartner @relation(fields: [patientId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([tenantId, patientId])
  @@index([tenantId, status])
  @@index([tenantId, verifiedAt])
  @@index([tenantId, insurerCode])
}

model BusinessPartnerExternalRef {
  id        String @id @default(uuid())
  tenantId  String
  partnerId String

  system       ExternalSystem
  externalId   String
  externalCode String?

  lastSyncedAt DateTime?
  metadata     Json?

  partner BusinessPartner @relation(fields: [partnerId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, system, externalId])
  @@unique([tenantId, partnerId, system])
  @@index([tenantId])
  @@index([tenantId, partnerId])
  @@index([tenantId, system])
}

// ------------------------------------------------
// Integrations
// ------------------------------------------------

model IntegrationSyncLog {
  id       String @id @default(uuid())
  tenantId String

  system    ExternalSystem
  direction IntegrationDirection
  status    IntegrationSyncStatus

  partnerId String?

  operation IntegrationOperation
  message   String?

  requestPayload  Json?
  responsePayload Json?

  startedAt  DateTime  @default(now())
  finishedAt DateTime?

  partner BusinessPartner? @relation(fields: [partnerId], references: [id], onDelete: SetNull)

  @@index([tenantId])
  @@index([tenantId, system])
  @@index([tenantId, partnerId])
  @@index([tenantId, startedAt])
  @@index([tenantId, status])
}

model ExternalCustomerLink {
  id       String @id @default(uuid())
  tenantId String

  partnerId String
  partner   BusinessPartner @relation(fields: [partnerId], references: [id], onDelete: Cascade)

  system ExternalSystem

  externalId String?

  status ExternalCustomerLinkStatus @default(ACTIVE)

  lastMatchedAt DateTime?
  lastSyncedAt  DateTime?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, partnerId, system])
  @@index([tenantId, system, externalId])
  @@index([tenantId, status])
}

model IntegrationConnection {
  id       String @id @default(uuid())
  tenantId String

  system   ExternalSystem
  authType IntegrationAuthType

  status IntegrationConnectionStatus @default(NOT_CONFIGURED)

  displayName String?

  // Datos no sensibles
  companyLogin String?
  userLogin    String?
  apiBaseUrl   String?
  domain       String?

  // Credencial permanente cifrada
  apiUserKeyEncrypted String?
  passwordEncrypted   String?

  // Tokens temporales cifrados
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?

  // Identificador persistente para refresh
  deviceTokenEncrypted String?

  // Datos de 2FA
  require2fa          Boolean @default(false)
  authSessionId       String?
  allowed2faProviders Json?

  connectedAt       DateTime?
  lastValidatedAt   DateTime?
  lastAuthAttemptAt DateTime?
  lastRefreshAt     DateTime?

  lastErrorAt      DateTime?
  lastErrorCode    String?
  lastErrorMessage String?

  metadata Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, system])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, system, status])
}

// ------------------------------------------------
// Preventive Medicine (Cases) 
// ------------------------------------------------

model PreventiveCase {
  id       String @id @default(uuid())
  tenantId String

  code   String
  title  String?
  status PreventiveCaseStatus @default(OPEN)

  patientId String

  pathologyId String?

  providerProfileId String?
  orgUnitId         String?
  locationId        String?

  serviceTypeId String?
  specialtyId   String?

  openedAt    DateTime  @default(now())
  completedAt DateTime?
  cancelledAt DateTime?

  notes     String?
  riskLevel PreventiveRiskLevel?

  followUpFrequency       FollowUpFrequency @default(NONE)
  followUpIntervalDays    Int?
  nextFollowUpAt          DateTime?
  lastFollowUpAt          DateTime?
  nextAutomaticFollowUpAt DateTime?

  tenant  Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  patient BusinessPartner @relation(fields: [patientId], references: [id], onDelete: Restrict)

  pathology Pathology? @relation(fields: [pathologyId], references: [id], onDelete: Restrict)

  providerProfile ProviderProfile? @relation(fields: [providerProfileId], references: [id], onDelete: Restrict)
  orgUnit         OrgUnit?         @relation(fields: [orgUnitId], references: [id], onDelete: Restrict)
  location        Location?        @relation(fields: [locationId], references: [id], onDelete: Restrict)

  serviceType ServiceType? @relation(fields: [serviceTypeId], references: [id], onDelete: Restrict)
  specialty   Specialty?   @relation(fields: [specialtyId], references: [id], onDelete: Restrict)

  followUps      PreventiveFollowUp[]
  timelineEvents PreventiveTimelineEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, patientId])
  @@index([tenantId, patientId, status])
  @@index([tenantId, pathologyId])
  @@index([tenantId, patientId, pathologyId])
  @@index([tenantId, providerProfileId])
  @@index([tenantId, orgUnitId])
  @@index([tenantId, locationId])
}

model PatientProviderAssignment {
  id String @id @default(uuid())

  tenantId String

  patientId         String
  providerProfileId String

  assignmentType PatientProviderAssignmentType @default(PREVENTIVE_FOLLOWUP)

  isPrimary Boolean @default(false)
  isActive  Boolean @default(true)

  startDate DateTime?
  endDate   DateTime?
  notes     String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  patient         BusinessPartner @relation("PatientAssignments", fields: [patientId], references: [id], onDelete: Restrict)
  providerProfile ProviderProfile @relation("ProviderAssignments", fields: [providerProfileId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, patientId, providerProfileId, assignmentType])
  @@index([tenantId])
  @@index([tenantId, patientId])
  @@index([tenantId, providerProfileId])
  @@index([tenantId, isActive])
  @@index([tenantId, isPrimary])
  @@index([tenantId, assignmentType])
  @@index([tenantId, patientId, isActive])
  @@index([tenantId, providerProfileId, isActive])
}

// ------------------------------------------------
// Preventive Medicine (Follow-ups) 
// ------------------------------------------------

model PreventiveFollowUp {
  id       String @id @default(uuid())
  tenantId String

  code String

  patientId         String
  preventiveCaseId  String
  pathologyId       String?
  providerProfileId String?
  orgUnitId         String?
  locationId        String?

  title           String
  description     String?
  notes           String?
  durationMinutes Int?

  status   PreventiveFollowUpStatus  @default(PLANNED)
  priority PreventivePriority        @default(NORMAL)
  channel  PreventiveFollowUpChannel @default(IN_PERSON)
  outcome  PreventiveOutcome?

  scheduledFor   DateTime
  performedAt    DateTime?
  nextFollowUpAt DateTime?
  cancelledAt    DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  patient         BusinessPartner  @relation(fields: [patientId], references: [id], onDelete: Restrict)
  preventiveCase  PreventiveCase   @relation(fields: [preventiveCaseId], references: [id], onDelete: Restrict)
  pathology       Pathology?       @relation(fields: [pathologyId], references: [id], onDelete: Restrict)
  providerProfile ProviderProfile? @relation(fields: [providerProfileId], references: [id], onDelete: Restrict)
  orgUnit         OrgUnit?         @relation(fields: [orgUnitId], references: [id], onDelete: Restrict)
  location        Location?        @relation(fields: [locationId], references: [id], onDelete: Restrict)

  timelineEvents PreventiveTimelineEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, patientId])
  @@index([tenantId, preventiveCaseId])
  @@index([tenantId, pathologyId])
  @@index([tenantId, providerProfileId])
  @@index([tenantId, status])
  @@index([tenantId, scheduledFor])
  @@index([tenantId, patientId, status])
}

// ------------------------------------------------
// Preventive Medicine (Campaigns / Outreach)
// ------------------------------------------------

model PreventiveCampaign {
  id       String @id @default(uuid())
  tenantId String

  code        String
  name        String
  description String?

  status  PreventiveCampaignStatus  @default(DRAFT)
  channel PreventiveCampaignChannel @default(WHATSAPP)

  pathologyId   String?
  serviceTypeId String?
  specialtyId   String?

  scheduledAt       DateTime?
  startedAt         DateTime?
  completedAt       DateTime?
  cancelledAt       DateTime?
  targetDescription String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  pathology   Pathology?   @relation(fields: [pathologyId], references: [id], onDelete: Restrict)
  serviceType ServiceType? @relation(fields: [serviceTypeId], references: [id], onDelete: Restrict)
  specialty   Specialty?   @relation(fields: [specialtyId], references: [id], onDelete: Restrict)

  recipients PreventiveCampaignRecipient[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, status])
  @@index([tenantId, pathologyId])
  @@index([tenantId, scheduledAt])
}

model PreventiveCampaignRecipient {
  id       String @id @default(uuid())
  tenantId String

  campaignId String
  patientId  String

  status PreventiveCampaignRecipientStatus @default(PENDING)

  sentAt      DateTime?
  deliveredAt DateTime?
  readAt      DateTime?
  respondedAt DateTime?

  responseText String?
  metadata     Json?

  tenant   Tenant             @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  campaign PreventiveCampaign @relation(fields: [campaignId], references: [id], onDelete: Restrict)
  patient  BusinessPartner    @relation(fields: [patientId], references: [id], onDelete: Restrict)

  timelineEvents PreventiveTimelineEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, campaignId, patientId])
  @@index([tenantId])
  @@index([tenantId, campaignId])
  @@index([tenantId, patientId])
  @@index([tenantId, status])
}

// ------------------------------------------------
// Preventive Medicine (Timeline / Events / Audit)
// ------------------------------------------------

model PreventiveTimelineEvent {
  id       String @id @default(uuid())
  tenantId String

  patientId           String
  preventiveCaseId    String?
  followUpId          String?
  campaignRecipientId String?

  type        PreventiveTimelineEventType
  title       String
  description String?
  occurredAt  DateTime                    @default(now())
  metadata    Json?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  patient           BusinessPartner              @relation(fields: [patientId], references: [id], onDelete: Restrict)
  preventiveCase    PreventiveCase?              @relation(fields: [preventiveCaseId], references: [id], onDelete: Restrict)
  followUp          PreventiveFollowUp?          @relation(fields: [followUpId], references: [id], onDelete: Restrict)
  campaignRecipient PreventiveCampaignRecipient? @relation(fields: [campaignRecipientId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())

  @@index([tenantId])
  @@index([tenantId, patientId])
  @@index([tenantId, preventiveCaseId])
  @@index([tenantId, followUpId])
  @@index([tenantId, occurredAt])
  @@index([tenantId, patientId, occurredAt])
}

// ------------------------------------------------
// Preventive Medicine (Patology / Risk Stratification)
// ------------------------------------------------

model Pathology {
  id       String @id @default(uuid())
  tenantId String

  code        String
  name        String
  description String?
  color       String?
  isActive    Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  patients            PatientPathology[]
  preventiveCases     PreventiveCase[]
  preventiveFollowUps PreventiveFollowUp[]
  preventiveCampaigns PreventiveCampaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, isActive])
  @@index([tenantId, name])
}

model PatientPathology {
  id       String @id @default(uuid())
  tenantId String

  patientId   String
  pathologyId String

  notes    String?
  isActive Boolean @default(true)

  diagnosedAt DateTime?
  resolvedAt  DateTime?

  tenant    Tenant          @relation(fields: [tenantId], references: [id], onDelete: Restrict)
  patient   BusinessPartner @relation(fields: [patientId], references: [id], onDelete: Restrict)
  pathology Pathology       @relation(fields: [pathologyId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, patientId, pathologyId])
  @@index([tenantId])
  @@index([tenantId, patientId])
  @@index([tenantId, pathologyId])
  @@index([tenantId, patientId, isActive])
}

// ------------------------------------------------
// Master data
// ------------------------------------------------

model BusinessPartner {
  id       String @id @default(uuid())
  tenantId String

  code     String
  type     PartnerType
  isActive Boolean     @default(true)

  firstName        String?
  lastName         String?
  organizationName String?

  email           String?
  emailNormalized String?
  phone           String?
  phoneNormalized String?

  birthDate DateTime?

  gender                Gender?
  nationalityCode       String?
  preferredLanguageCode String?

  deceasedAt DateTime?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  nationality       Country? @relation("BPNationality", fields: [nationalityCode], references: [code], onDelete: Restrict)
  preferredLanguage Locale?  @relation("BPPreferredLanguage", fields: [preferredLanguageCode], references: [code], onDelete: Restrict)

  addresses             BusinessPartnerAddress[]
  identities            BusinessPartnerIdentity[]
  insuranceCoverages    PatientInsuranceCoverage[]
  externalRefs          BusinessPartnerExternalRef[]
  integrationSyncLogs   IntegrationSyncLog[]
  externalCustomerLinks ExternalCustomerLink[]

  roles                    BusinessPartnerRole[]
  providerProfile          ProviderProfile?
  preventiveCases          PreventiveCase[]
  preventiveFollowUps      PreventiveFollowUp[]
  patientAssignments       PatientProviderAssignment[]   @relation("PatientAssignments")
  patientPathologies       PatientPathology[]
  campaignRecipients       PreventiveCampaignRecipient[]
  preventiveTimelineEvents PreventiveTimelineEvent[]

  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  localeCode String?

  @@unique([tenantId, code])
  @@index([tenantId])
  @@index([tenantId, email])
  @@index([tenantId, phone])
  @@index([tenantId, code])
  @@index([tenantId, birthDate])
  @@index([tenantId, gender])
}

// ------------------------------------------------
// Catalog data
// ------------------------------------------------

model ServiceType {
  id       String  @id @default(uuid())
  tenantId String
  code     String
  isActive Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  preventiveCases     PreventiveCase[]
  preventiveCampaigns PreventiveCampaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
}

// Idioma / Locale (BCP-47)
// Usa códigos tipo: es-ES, fr-BE, nl-BE, de-DE, it-IT, pt-PT.

model Locale {
  code     String  @id
  language String
  region   String?
  name     String
  isActive Boolean @default(true)

  tenantsDefault   Tenant[]       @relation("TenantDefaultLocale")
  tenantsSupported TenantLocale[]
  translations     Translation[]

  businessPartnersPreferredLanguage BusinessPartner[] @relation("BPPreferredLanguage")
}

// Zona horaria (IANA)
// Ej: Europe/Brussels, Europe/Madrid.

model TimeZone {
  id       String  @id // usa el propio IANA ID como PK
  label    String // "Europe/Brussels"
  isActive Boolean @default(true)

  tenants Tenant[]
  // userPreferences UserPreference[]
}

// Moneda (ISO 4217)
// Ej: EUR, GBP, CHF.

model Currency {
  code     String  @id // "EUR"
  name     String
  symbol   String?
  decimals Int     @default(2)
  isActive Boolean @default(true)

  tenants   Tenant[]
  countries Country[] // ✅ países cuya moneda oficial es esta
}

// País (ISO 3166-1 alpha-2)

model Country {
  code     String  @id
  name     String
  euMember Boolean @default(false)
  isActive Boolean @default(true)

  currencyCode String
  currency     Currency @relation(fields: [currencyCode], references: [code], onDelete: Restrict)

  tenants   Tenant[]
  locations Location[]

  businessPartnerAddresses BusinessPartnerAddress[]

  businessPartnerNationalities BusinessPartner[] @relation("BPNationality")

  identityIssuingCountries BusinessPartnerIdentity[] @relation("IdentityIssuingCountry")
  identityNationalities    BusinessPartnerIdentity[] @relation("IdentityNationality")

  @@index([currencyCode])
}

model Specialty {
  id       String  @id @default(uuid())
  tenantId String
  code     String
  isActive Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Restrict)

  providerSpecialties ProviderSpecialty[]
  preventiveCases     PreventiveCase[]
  preventiveCampaigns PreventiveCampaign[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, code])
  @@index([tenantId])
}
